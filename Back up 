/* all of this bellof is for the nav bar */

.topnav {
  background-color: #535F80;
  font-family: sans-serif;
  position: relative; 
}

.topnav a {
  float: left;
  padding: 14px 16px;
  text-decoration: none;
  color: #081F62;
  font-weight: bold;
  font-size: 17px;
}

.topnav a:hover {
  background-color: #081F62;
  color: #aaa;
}

.topnav a.active {
  background-color: #051747;
  color: #E7E9F0;
}

.dropdown {
  float: left;
  position: relative;
}

.dropdown-content {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 160px;
  background-color: #535F80;
  z-index: 10000; 
}

.dropdown-content a {
  display: block;
  padding: 12px 16px;
  color: #081F62;
  text-decoration: none;
}

.dropdown-content a:hover {
  background-color: #081F62;
  color: #aaa;
}

.dropdown:hover .dropdown-content {
  display: block;
}

.topnav::after {
  content: "";
  display: table;
  clear: both;
}

.dropdown-content-outside {
  display: none;
  position: absolute;
  min-width: 160px;
  background-color: #535F80;
  z-index: 10000;
}

.dropdown-content-outside a {
  display: block;
  padding: 12px 16px;
  color: #081F62;
  text-decoration: none;
}

.dropdown-content-outside a:hover {
  background-color: #081F62;
  color: #aaa;
}
